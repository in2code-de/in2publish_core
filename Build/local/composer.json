{
	"name": "in2code/in2publish-dev-t3v14-cpv14",
	"description": "Content Publisher Development Environment",
	"type": "project",
	"license": "GPL-3.0-or-ater",
	"authors": [
		{
			"name": "Oliver Eglseder",
			"email": "oliver.eglseder@in2code.de"
		}
	],
	"repositories": {
		"0": {
			"type": "path",
			"url": "/packages/*"
		},
		"1": {
			"type": "vcs",
			"url": "https://github.com/in2code-de/stack-test"
		},
		"2": {
			"type": "vcs",
			"url": "https://github.com/in2code-de/mysql-loader"
		},
		"3": {
			"type": "vcs",
			"url": "https://github.com/in2code-de/build-essentials"
		},
		"4": {
			"type": "vcs",
			"url": "https://github.com/in2code-de/process-manager"
		}
	},
	"require": {
		"php": ">= 8.2.0 <= 8.4.99",
		"ext-json": "*",
		"ext-pdo": "*",
		"ext-ssh2": "*",
		"ext-zip": "*",
		"georgringer/news": "^14.0",
		"helhum/typo3-console": "^8.2",
		"in2code/in2publish_core": "dev-develop-v14",
		"typo3/cms-adminpanel": "^14.2",
		"typo3/cms-backend": "^14.2",
		"typo3/cms-belog": "^14.2",
		"typo3/cms-beuser": "^14.2",
		"typo3/cms-core": "^14.2",
		"typo3/cms-dashboard": "^14.2",
		"typo3/cms-extbase": "^14.2",
		"typo3/cms-extensionmanager": "^14.2",
		"typo3/cms-felogin": "^14.2",
		"typo3/cms-filelist": "^14.2",
		"typo3/cms-fluid": "^14.2",
		"typo3/cms-fluid-styled-content": "^14.2",
		"typo3/cms-form": "^14.2",
		"typo3/cms-frontend": "^14.2",
		"typo3/cms-impexp": "^14.2",
		"typo3/cms-indexed-search": "^14.2",
		"typo3/cms-info": "^14.2",
		"typo3/cms-install": "^14.2",
		"typo3/cms-linkvalidator": "^14.2",
		"typo3/cms-lowlevel": "^14.2",
		"typo3/cms-opendocs": "^14.2",
		"typo3/cms-recordlist": "^14.2",
		"typo3/cms-recycler": "^14.2",
		"typo3/cms-redirects": "^14.2",
		"typo3/cms-reports": "^14.2",
		"typo3/cms-rte-ckeditor": "^14.2",
		"typo3/cms-scheduler": "^14.2",
		"typo3/cms-seo": "^14.2",
		"typo3/cms-setup": "^14.2",
		"typo3/cms-styleguide": "^14.2",
		"typo3/cms-sys-note": "^14.2",
		"typo3/cms-t3editor": "^14.2",
		"typo3/cms-tstemplate": "^14.2",
		"typo3/cms-viewpage": "^14.2",
		"typo3/cms-workspaces": "^14.2"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"co-stack/build-essentials": true,
			"helhum/dotenv-connector": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"typo3/cms": {
			"web-dir": "public"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"In2code\\In2publishCore\\Tests\\": "/app/Tests/"
		}
	},
	"require-dev": {
		"typo3/testing-framework": "^9.1",
		"co-stack/build-essentials": "@dev",
		"co-stack/mysql-loader": "@dev",
		"co-stack/process-manager": "@dev"
	}
}
